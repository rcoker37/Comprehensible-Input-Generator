# All local-dev env vars in one place. Copy to .env.local (gitignored) and
# fill in. Read by:
#   - Vite (client) — only VITE_* vars are exposed to the browser bundle
#   - npx supabase functions serve --env-file .env.local — Edge Function env

# --- Required for the client to talk to local Supabase ---
# Standard local Supabase URL + the demo anon key (printed by `npx supabase
# status`). Anon key is fixed across local installs and not a real secret.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# --- Optional, only needed for local audio playback ---
# generate-audio Edge Function reads these from the Deno env and refuses to
# synthesize if missing. Pass this file with `--env-file .env.local` when
# starting `supabase functions serve`.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
