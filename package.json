{
  "name": "comprehensible-input-generator",
  "private": true,
  "workspaces": ["client"],
  "scripts": {
    "postinstall": "mkdir -p client/public/dict && cp node_modules/@aiktb/kuromoji/dict/* client/public/dict/",
    "dev": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "generate-seed": "npx tsx scripts/generate-seed-sql.ts",
    "generate-frequency": "npx tsx scripts/generate-jpdb-frequency.ts",
    "generate-frequency-by-entry": "npx tsx scripts/generate-jpdb-frequency-by-entry.ts",
    "sync-prod": "bash scripts/sync-prod-to-local.sh",
    "record-test-dictionary": "node scripts/record-test-dictionary.mjs",
    "import-story-local": "node scripts/import-story-local.mjs",
    "test": "npm run test --workspace=client",
    "test:index": "npm run test:index --workspace=client",
    "test:index:accept": "npm run test:index:accept --workspace=client"
  }
}
